# VoiceFlow environment variables
# Copy this to .env and fill in your keys

# --- Required ---

# Deepgram API key (free at https://deepgram.com)
# Used for speech-to-text (STT)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Groq API key (free at https://console.groq.com)
# Used for LLM transcript cleanup
GROQ_API_KEY=your_groq_api_key_here

# --- Optional overrides (all have defaults in config.toml) ---

# Override the hotkey (default: KEY_RIGHTALT)
# VOICEFLOW_HOTKEY=KEY_RIGHTALT

# Override STT language (default: en)
# VOICEFLOW_LANGUAGE=en

# Override overlay color hex (default: #7C3AED)
# VOICEFLOW_OVERLAY_COLOR=#7C3AED
